# =============================================================================
# KOMPRALO — Variables de entorno
# =============================================================================
# Copia este archivo a .env.local y completa los valores reales.
# NUNCA subas .env.local ni ningún archivo con valores reales al repositorio.
# .env.local está en .gitignore — verifica antes de cada commit.
# =============================================================================

# ─── PÚBLICAS (visible en el cliente / navegador) ─────────────────────────────
# Todas las variables NEXT_PUBLIC_* son expuestas al navegador.
# No pongas secretos en ellas.

# URL pública de la aplicación (sin trailing slash).
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
NEXT_PUBLIC_APP_URL=

# Supabase: URL del proyecto (pública — solo identifica el proyecto)
# Obtén en: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase: Anon key (pública — acceso limitado, sujeto a RLS)
# Obtén en: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── PRIVADAS (solo servidor — NUNCA al cliente) ──────────────────────────────
# Las siguientes variables NO deben tener prefijo NEXT_PUBLIC_.
# Next.js las mantiene en el servidor; no se incluyen en el bundle del cliente.

# Supabase: Service Role Key (bypasea RLS — úsala solo en webhook y server actions)
# Obtén en: Supabase Dashboard → Settings → API → service_role
# ⚠ NUNCA expongas esta key. Solo para código server-side.
SUPABASE_SERVICE_ROLE_KEY=

# Firma la cookie HttpOnly creada por el enlace post-pago de un solo correo.
# Server-only. Usa un valor aleatorio de al menos 32 caracteres en cada ambiente.
ACCESS_TOKEN_SECRET=

# Stripe: Secret Key (úsala solo en el servidor)
# Obtén en: https://dashboard.stripe.com/apikeys
# Usa STRIPE_TEST_SECRET_KEY_PREFIX... en desarrollo y STRIPE_LIVE_SECRET_KEY_PREFIX... en producción.
STRIPE_SECRET_KEY=

# Stripe: Webhook Signing Secret (valida que los eventos vienen de Stripe)
# Obtén en: Stripe Dashboard → Webhooks → tu endpoint → Signing secret
# Con Stripe CLI local: stripe listen → imprime el STRIPE_WEBHOOK_SECRET_PREFIX...
STRIPE_WEBHOOK_SECRET=

# Resend: API Key para envío de emails transaccionales
# Obtén en: https://resend.com/api-keys
RESEND_API_KEY=

# Resend: Dirección del remitente (opcional)
# Formato: Nombre <correo@tudominio.com>
# El dominio debe estar verificado en Resend antes de usar en producción.
# Default si se omite: KOMPRALO <hola@kompralo.mx>
RESEND_FROM_EMAIL=

# ─── VIRTUAL ASSISTANT ────────────────────────────────────────────────────────
# true  = muestra el asistente virtual en /invitaciones, /invitaciones/precios,
#         /checkout/success y /cliente
# false = oculta el asistente virtual (default seguro si la variable no existe)
NEXT_PUBLIC_VIRTUAL_ASSISTANT_ENABLED=false

# true  = muestra el asistente dentro del dashboard cuando el plan tambien esta permitido.
# false = oculta el asistente del dashboard.
NEXT_PUBLIC_DASHBOARD_ASSISTANT_ENABLED=false

# Dashboard Assistant by Plan
# Lista de planes donde el asistente del dashboard esta permitido.
# Opciones: basic,premium,deluxe
# Ejemplo para solo Premium y Deluxe:
DASHBOARD_ASSISTANT_ALLOWED_PLANS=premium,deluxe

# true = permite que /api/assistant use OpenAI solo para mensajes creativos/complejos.
# false = reglas locales solamente.
ASSISTANT_AI_ENABLED=false

# OpenAI: Server-only. Never expose as NEXT_PUBLIC.
# Necesaria solo si ASSISTANT_AI_ENABLED=true.
OPENAI_API_KEY=

# ─── DASHBOARD ────────────────────────────────────────────────────────────────
# Controla el acceso al dashboard /dashboard.
#
# En producción con auth magic link (FASE 7B):
#   ADMIN_ACCESS_ENABLED=false — los clientes acceden via sesión de Supabase Auth.
#
# En desarrollo o sin auth configurado:
#   ADMIN_ACCESS_ENABLED=true — acceso libre sin sesión (útil para pruebas locales).
#
# ⚠ Con ADMIN_ACCESS_ENABLED=true en producción, cualquier persona con el UUID
# puede editar cualquier invitación. Solo úsalo durante desarrollo o pruebas
# controladas; en producción usa false con auth configurado.
ADMIN_ACCESS_ENABLED=false
